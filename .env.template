# --- Secrets (protect at the level of the source data) ---
BRUME_HMAC_SECRET=X7kymP9qL2nR4vWz   # ≥ 16 chars, high entropy
BRUME_FPE_KEY=A3bC9dE2fG7hI1jK       # 16, 24 or 32 chars

# --- Source (read-only) ---
BRUME_SOURCE_HOST=localhost
BRUME_SOURCE_PORT=5432               # optional, default 5432
BRUME_SOURCE_DB=postgres
BRUME_SOURCE_USER=postgres
BRUME_SOURCE_PASSWORD=postgres
BRUME_SOURCE_SSLMODE=disable         # disable | prefer | require | verify-ca | verify-full
BRUME_SCHEMA=public

# --- Target = local Postgres (required only when BRUME_SINK_TYPE=JDBC) ---
# In DUMP / NULL sink modes Brume skips the target entirely
# you can comment out this whole block.
BRUME_TARGET_HOST=localhost
BRUME_TARGET_PORT=5460               # optional, default 5460
BRUME_TARGET_DB=postgres
BRUME_TARGET_USER=postgres
BRUME_TARGET_PASSWORD=postgres

# --- Options ---
BRUME_PARALLELISM=20                 # HikariCP pool size, default 20
BRUME_LOCALE=en                      # Datafaker locale (en, fr, de, …)

# --- Sink mode (JDBC default, DUMP for SQL file export) ---
# BRUME_SINK_TYPE=DUMP
# BRUME_SINK_OUTPUT_PATH=./dumps/dump.sql.gz
# BRUME_SINK_COMPRESSION=GZIP        # NONE | GZIP | ZSTD
